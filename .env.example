# App
ENVIRONMENT=local
SECRET_KEY=change-me
ACCESS_TOKEN_EXP_MINUTES=1440
REFRESH_TOKEN_EXP_DAYS=14
JWT_ALGORITHM=HS256
CORS_ORIGINS=*

# Database
DATABASE_URL=mysql+pymysql://bookstopper:change-me@db:3306/bookstopper

# External APIs
ALADIN_API_KEY=
GOOGLE_BOOKS_API_KEY=
OPENAI_API_KEY=

# Firebase
FCM_SERVICE_ACCOUNT_JSON_PATH=/app/secrets/firebase-adminsdk.json

# Local upload/static serving
UPLOAD_DIR=/app/uploads
STATIC_BASE_URL=/static/uploads/

# Optional S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=
S3_PUBLIC_BASE_URL=

# Optional SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
EMAIL_VERIFICATION_EXP_MINUTES=10
EMAIL_VERIFICATION_RESEND_SECONDS=60
